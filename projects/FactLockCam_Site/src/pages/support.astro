---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import { mechanismHeadline } from '../copy/marketing';

const faqs = [
  {
    q: 'How do I sign in?',
    a: 'FactLockCam uses passwordless email OTP. Enter your email in the app, then paste the one-time code from your inbox. No password is stored on our servers.',
  },
  {
    q: 'Can FactLockCam recover my encrypted files?',
    a: 'No. Only you hold the keys—we cannot decrypt your archive or reset a lost backup password. Export a .factlock sovereign key backup from Account & Settings and store it safely. Cloud sync stores ciphertext we cannot read; it is not a downloadable photo library backup.',
  },
  {
    q: 'How does Send Proof work?',
    a: 'From an archive item, tap Send Proof, set a one-time password, and share the tamper-proof certificate PDF plus courier URL through the iOS share sheet. Recipients unlock media in a browser at the link you send.',
  },
  {
    q: 'What data leaves my device?',
    a: 'Proof hashes and ledger metadata sync to our backend. Sealed media lives on your device as encrypted .seal files. After sealing, optional blind ciphertext may upload for the same account—we cannot read it, and you do not download it like a cloud photo backup. Send Proof shares a time-limited courier link when you choose.',
  },
  {
    q: 'How do I back up my archive?',
    a: 'Use Account & Settings → Export archive keys to create a password-protected .factlock file. That backs up your sovereign decryption keys only—not photos or videos from our servers. Re-export periodically or before Lock Archive, uninstall, or device replacement.',
  },
  {
    q: 'What is Lock Archive vs Burn Account?',
    a: 'Lock Archive removes cryptographic keys from this device but keeps local .seal files. Import your .factlock backup to unlock the app again; cloud data for your account is unchanged. Burn Account permanently deletes your account, cloud ciphertext, local archive, and keys. A .factlock from before Burn cannot restore that burned identity.',
  },
  {
    q: 'What if I reinstall the app?',
    a: 'Uninstalling removes local keys and usually local sealed files. Sign in with the same email, then import your .factlock file on the restore screen to decrypt cloud sync again. Without .factlock, encrypted cloud and local assets are inaccessible.',
  },
  {
    q: 'How do I delete my account?',
    a: 'Open Account & Settings → Burn Account and confirm twice. This permanently deletes your Supabase identity, linked cloud storage, local archive, and keys. A prior .factlock backup cannot resurrect that account.',
  },
];
---

<Layout
  title="Support"
  description={`FactLockCam support — ${mechanismHeadline}. Help with capture, Digital DNA sealing, and Send Proof.`}
>
  <section class="mx-auto max-w-3xl px-6 py-12 lg:py-16">
    <header class="mb-10">
      <p class="mono-label mb-3">We're here to help</p>
      <h1 class="font-mono text-3xl font-bold text-verified-neon md:text-4xl">Support</h1>
      <p class="mt-4 text-white/70">
        Need help with capture, your sovereign zero-knowledge archive, or Send Proof? Reach us
        directly—we respond to support requests for active App Store builds.
      </p>
    </header>

    <div class="panel mb-10 p-6">
      <p class="mono-label mb-2">Direct contact</p>
      <a
        href="mailto:support@factlockcam.com"
        class="font-mono text-xl text-kinetic-green hover:text-verified-neon"
      >
        support@factlockcam.com
      </a>
      <p class="mt-3 text-sm text-white/60">
        Include your device model, iOS version, and a description of the issue. Do not email
        encryption keys, OTP codes, or courier passwords.
      </p>
    </div>

    <h2 class="mb-6 font-mono text-xl text-white">FAQ</h2>
    <dl class="space-y-6">
      {
        faqs.map((item) => (
          <div class="panel p-5">
            <dt class="font-mono text-sm font-semibold text-kinetic-green">{item.q}</dt>
            <dd class="mt-2 text-sm text-white/70">{item.a}</dd>
          </div>
        ))
      }
    </dl>

    <p class="mt-10 text-sm text-white/50">
      Legal documents:
      <a href="/privacy" class="text-kinetic-green hover:underline">Privacy Policy</a>
      ·
      <a href="/terms" class="text-kinetic-green hover:underline">Terms of Service</a>
    </p>
  </section>
</Layout>
