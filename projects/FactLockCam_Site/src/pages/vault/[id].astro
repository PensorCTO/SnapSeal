---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import VaultCourier from '../../components/VaultCourier';

const { id } = Astro.params;
---

<Layout
  title="Courier Unlock"
  description="Unlock and verify an encrypted FactLockCam courier package."
  hideNav={false}
>
  <VaultCourier client:only="react" packageId={id ?? null} />
</Layout>
