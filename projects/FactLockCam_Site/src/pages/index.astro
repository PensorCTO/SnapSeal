---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import {
  pageTitle,
  metaDescription,
  heroLabel,
  heroHeadline,
  heroHeadlineAccent,
  heroLead,
  heroPrivacyLine,
  heroTaglineLine1,
  heroTaglineLine2,
  heroBackgroundSrc,
  heroImageAlt,
  pillarWhatLabel,
  panel1Title,
  panel1Label,
  panel1Body,
  panel1Bullets,
  panel2Title,
  panel2Label,
  panel2Body,
  panel2Bullets,
  pillarWhyLabel,
  whyHeadline,
  whyBody,
  whyUseCases,
  trustLabel,
  trustHeadline,
  trustBody,
  trustDisclaimer,
} from '../copy/marketing';
---

<Layout title={pageTitle} description={metaDescription} hideNav={true}>
  <section class="sales-hero relative min-h-[100svh] overflow-hidden">
    <img
      src={heroBackgroundSrc}
      alt={heroImageAlt}
      class="sales-hero__bg"
      width="1920"
      height="1080"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="sales-hero__shade" aria-hidden="true"></div>
    <div class="sales-hero__grid" aria-hidden="true"></div>

    <div class="relative z-10 flex min-h-[100svh] flex-col">
      <header class="flex items-center justify-between px-6 py-5 md:px-10">
        <a href="/" class="sales-logo" aria-label="FactLockCam home">
          <span class="sales-logo__mark">fact</span><span class="sales-logo__lock">lock</span><span class="sales-logo__cam">cam</span>
        </a>
        <nav class="hidden items-center gap-6 md:flex" aria-label="Compliance">
          <a href="/guide" class="sales-nav-link">Guide</a>
          <a href="/support" class="sales-nav-link">Support</a>
          <a href="/privacy" class="sales-nav-link">Privacy</a>
        </nav>
      </header>

      <div class="flex flex-1 flex-col justify-end px-6 pb-10 md:px-10 md:pb-14">
        <div class="mx-auto w-full max-w-6xl">
          <div class="grid gap-10 lg:grid-cols-2 lg:items-end">
            <div class="max-w-xl">
              <p class="mono-label mb-3 text-white/80">{heroLabel}</p>
              <h1 class="font-mono text-3xl font-bold leading-tight text-white md:text-4xl lg:text-[2.65rem]">
                {heroHeadline}<br />
                <span class="text-verified-neon">{heroHeadlineAccent}</span>
              </h1>
              <p class="mt-5 text-base text-white/75 md:text-lg">
                {heroLead}
              </p>
              <p class="mt-3 text-base text-white/70 md:text-lg">{heroPrivacyLine}</p>
              <div class="mt-8 flex flex-wrap gap-4">
                <a
                  href="https://apps.apple.com/app/factlockcam"
                  class="btn-primary"
                  rel="noopener noreferrer"
                >
                  Download on the App Store
                </a>
                <a href="/guide" class="btn-ghost border-white/30 text-white hover:border-kinetic-green">
                  See how it works
                </a>
              </div>
            </div>
            <div class="lg:text-right">
              <p class="font-mono text-sm uppercase tracking-[0.2em] text-white/90 md:text-base">
                {heroTaglineLine1}<br />
                <span class="text-kinetic-green">{heroTaglineLine2}</span>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-titanium-edge bg-titanium-deep px-6 py-20 md:px-10">
    <div class="mx-auto max-w-6xl">
      <header class="mb-10">
        <p class="mono-label mb-3">{pillarWhatLabel}</p>
        <h2 class="font-mono text-xl font-bold text-white md:text-2xl">How it works</h2>
      </header>
      <div class="grid gap-8 md:grid-cols-2">
        <article class="sales-panel">
          <p class="sales-panel__title">{panel1Title}</p>
          <div class="sales-panel__body">
            <p class="mono-label mb-2 text-kinetic-green">{panel1Label}</p>
            <p class="text-sm leading-relaxed text-white/70">{panel1Body}</p>
            <ul class="mt-4 space-y-2 font-mono text-xs text-white/50">
              {panel1Bullets.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </article>
        <article class="sales-panel">
          <p class="sales-panel__title">{panel2Title}</p>
          <div class="sales-panel__body">
            <p class="mono-label mb-2 text-verified-neon">{panel2Label}</p>
            <p class="text-sm leading-relaxed text-white/70">{panel2Body}</p>
            <ul class="mt-4 space-y-2 font-mono text-xs text-white/50">
              {panel2Bullets.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="border-t border-titanium-edge bg-titanium-panel px-6 py-20 md:px-10">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mono-label mb-4">{pillarWhyLabel}</p>
      <h2 class="font-mono text-2xl font-bold text-white md:text-3xl">{whyHeadline}</h2>
      <p class="mx-auto mt-5 text-sm leading-relaxed text-white/70 md:text-base">{whyBody}</p>
      <ul class="mt-10 flex flex-wrap justify-center gap-3">
        {
          whyUseCases.map((item) => (
            <li class="sales-use-case">{item}</li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="border-t border-titanium-edge bg-titanium-deep px-6 py-16 md:px-10">
    <div class="mx-auto max-w-6xl text-center">
      <p class="mono-label mb-4">{trustLabel}</p>
      <h2 class="font-mono text-2xl font-bold text-white md:text-3xl">{trustHeadline}</h2>
      <p class="mx-auto mt-4 max-w-2xl text-sm leading-relaxed text-white/70 md:text-base">{trustBody}</p>
      <p class="mx-auto mt-4 max-w-2xl text-sm text-white/50 md:text-base">{trustDisclaimer}</p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/privacy" class="btn-ghost">Privacy Policy</a>
        <a href="/terms" class="btn-ghost">Terms of Service</a>
        <a href="/support" class="btn-ghost">Support</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
