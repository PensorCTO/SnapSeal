---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
---

<Layout
  title="FactLockCam — Lens-to-Cloud Authenticated Archive"
  description="Permanently authenticated from the instant of capture. Your personal history, safe from modification. Native iOS capture with tamper-evident chain-of-custody."
  hideNav={true}
>
  <!-- Master sales pitch hero (template: factlockcam-hero-sales.png) -->
  <section class="sales-hero relative min-h-[100svh] overflow-hidden">
    <img
      src="/images/factlockcam-hero-sales.png"
      alt="FactLockCam secure capture and personal history archive"
      class="sales-hero__bg"
      width="1920"
      height="1080"
      loading="eager"
      fetchpriority="high"
    />
    <div class="sales-hero__shade" aria-hidden="true"></div>

    <div class="relative z-10 flex min-h-[100svh] flex-col">
      <header class="flex items-center justify-between px-6 py-5 md:px-10">
        <a href="/" class="sales-logo" aria-label="FactLockCam home">
          <span class="sales-logo__mark">fact</span><span class="sales-logo__lock">lock</span><span class="sales-logo__cam">cam</span>
        </a>
        <nav class="hidden items-center gap-6 md:flex" aria-label="Compliance">
          <a href="/guide" class="sales-nav-link">Guide</a>
          <a href="/support" class="sales-nav-link">Support</a>
          <a href="/privacy" class="sales-nav-link">Privacy</a>
        </nav>
      </header>

      <div class="flex flex-1 flex-col justify-end px-6 pb-10 md:px-10 md:pb-14">
        <div class="mx-auto w-full max-w-6xl">
          <div class="grid gap-10 lg:grid-cols-2 lg:items-end">
            <div class="max-w-xl">
              <p class="mono-label mb-3 text-white/80">Lens-to-cloud attestation</p>
              <h1 class="font-mono text-3xl font-bold leading-tight text-white md:text-4xl lg:text-[2.65rem]">
                Permanently authenticated<br />
                <span class="text-verified-neon">from the instant of capture.</span>
              </h1>
              <p class="mt-5 text-base text-white/75 md:text-lg">
                FactLockCam seals photos and video on-device with hardware-backed integrity,
                anchors hashes to a public ledger, and delivers tamper-evident proof through
                Send Proof courier links — not a browser clone of the mobile app.
              </p>
              <div class="mt-8 flex flex-wrap gap-4">
                <a
                  href="https://apps.apple.com/app/factlockcam"
                  class="btn-primary"
                  rel="noopener noreferrer"
                >
                  Download on the App Store
                </a>
                <a href="/guide" class="btn-ghost border-white/30 text-white hover:border-kinetic-green">
                  How chain-of-custody works
                </a>
              </div>
            </div>
            <div class="lg:text-right">
              <p class="font-mono text-sm uppercase tracking-[0.2em] text-white/90 md:text-base">
                Your personal history,<br />
                <span class="text-kinetic-green">completely safe from modification.</span>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Product story panels -->
  <section class="border-t border-titanium-edge bg-titanium-deep px-6 py-20 md:px-10">
    <div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-2">
      <article class="sales-panel">
        <p class="sales-panel__title">Real-Time Secure Capture</p>
        <div class="sales-panel__body">
          <p class="mono-label mb-2 text-kinetic-green">Native iOS · hardware attestation</p>
          <p class="text-sm leading-relaxed text-white/70">
            Capture originates exclusively in the native app — Secure Enclave signing, sensor-level
            integrity, and encrypted local archive before any cloud sync. No browser capture path.
          </p>
          <ul class="mt-4 space-y-2 font-mono text-xs text-white/50">
            <li>LOCATION + timestamp telemetry at seal</li>
            <li>SHA-256 fingerprint + AES-GCM vault</li>
            <li>Optional Polygon notarization saga</li>
          </ul>
        </div>
      </article>
      <article class="sales-panel">
        <p class="sales-panel__title">Personal History Archive</p>
        <div class="sales-panel__body">
          <p class="mono-label mb-2 text-verified-neon">Verified · tamper-evident</p>
          <p class="text-sm leading-relaxed text-white/70">
            Every sealed item carries a cryptographic fingerprint. Send Proof shares a certificate
            PDF plus a password-protected courier link — recipients unlock and verify in the browser
            without installing the app.
          </p>
          <ul class="mt-4 space-y-2 font-mono text-xs text-white/50">
            <li>Chain-of-custody on this device</li>
            <li>Courier unlock at archive.factlockcam.com</li>
            <li>Utility share sheet — no in-app messaging</li>
          </ul>
        </div>
      </article>
    </div>
  </section>

  <!-- Trust + compliance -->
  <section class="border-t border-titanium-edge bg-titanium-panel px-6 py-16 md:px-10">
    <div class="mx-auto max-w-6xl text-center">
      <p class="mono-label mb-4">Risk reduction, not absolute certainty</p>
      <h2 class="font-mono text-2xl font-bold text-white md:text-3xl">
        Built for disclosure workflows
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-sm text-white/60 md:text-base">
        FactLockCam supports workflow and disclosure with tamper-evident heuristics. It does not
        guarantee admissibility under FRE 902 or claim mathematical certainty of truth.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/privacy" class="btn-ghost">Privacy Policy</a>
        <a href="/terms" class="btn-ghost">Terms of Service</a>
        <a href="/support" class="btn-ghost">Support</a>
      </div>
    </div>
  </section>

  <footer class="border-t border-titanium-edge bg-titanium-deep px-6 py-8 text-center font-mono text-xs text-white/40">
    <p>&copy; {new Date().getFullYear()} FactLockCam. Capture on native iOS. Courier unlock on the web.</p>
    <p class="mt-2">
      <a href="mailto:support@factlockcam.com" class="hover:text-kinetic-green">support@factlockcam.com</a>
    </p>
  </footer>
</Layout>
