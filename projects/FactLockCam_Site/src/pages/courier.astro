---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import VaultCourier from '../components/VaultCourier';

const packageId = Astro.url.searchParams.get('pkg');
---

<Layout
  title="Courier Unlock"
  description="Unlock and verify an encrypted FactLockCam courier package."
>
  <VaultCourier client:only="react" packageId={packageId} />
</Layout>
