SUPABASE_URL=
SUPABASE_ANON_KEY=
# Polygon saga (async anchor-relay). Set false to use simulated chain only.
USE_POLYGON_NOTARIZER=true
# Polygon mainnet JSON-RPC for receipt polling (same Alchemy key as anchor-relay).
POLYGON_RPC_URL=

# --- Courier / Send Proof (optional) ---
# Public HTTPS origin for recipient unlock links: {WEB_ARCHIVE_BASE_URL}/courier?pkg={uuid}
# Production: https://archive.factlockcam.com
# Tunnel QA: paste Ngrok origin after scripts/start_qa_env.sh
WEB_ARCHIVE_BASE_URL=https://archive.factlockcam.com
# Required for release/profile Send Proof QA. App Store submission builds must use false.
ENABLE_PROOF_LINKS=false
# Use development for device QA; use production only when syncing release dart_defines.
APP_ENVIRONMENT=development
