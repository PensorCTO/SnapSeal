# Copy to .env.qa.local (for VS Code "iOS (QA Tunnel)" launch) or merge into .env.local.
# Then run: ./scripts/sync_flutter_dart_defines.sh

SUPABASE_URL=
SUPABASE_ANON_KEY=

# Hosted archive (default for Send Proof QA when courier SPA is live).
WEB_ARCHIVE_BASE_URL=https://archive.factlockcam.com

# Tunnel alternative — uncomment and paste Ngrok origin after start_qa_env.sh:
# WEB_ARCHIVE_BASE_URL=https://YOUR-NGROK-SUBDOMAIN.ngrok-free.app

ENABLE_PROOF_LINKS=true
APP_ENVIRONMENT=development

USE_POLYGON_NOTARIZER=true
POLYGON_RPC_URL=
