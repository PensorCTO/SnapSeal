{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "factlockcam_app (Supabase from .env.local)",
      "cwd": "${workspaceFolder}/factlockcam_app",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "toolArgs": ["--dart-define-from-file=dart_defines.json"],
      "preLaunchTask": "factlockcam: sync Flutter dart defines"
    },
    {
      "name": "factlockcam_app (Release)",
      "cwd": "${workspaceFolder}/factlockcam_app",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "release",
      "toolArgs": ["--dart-define-from-file=dart_defines.json"],
      "preLaunchTask": "factlockcam: sync Flutter dart defines"
    },
    {
      "name": "iOS (QA Tunnel)",
      "cwd": "${workspaceFolder}/factlockcam_app",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "toolArgs": ["--dart-define-from-file=dart_defines.json"],
      "preLaunchTask": "factlockcam: sync Flutter dart defines (QA)"
    },
    {
      "name": "iOS (QA Tunnel, Release)",
      "cwd": "${workspaceFolder}/factlockcam_app",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "release",
      "toolArgs": ["--dart-define-from-file=dart_defines.json"],
      "preLaunchTask": "factlockcam: sync Flutter dart defines (QA)"
    }
  ]
}
