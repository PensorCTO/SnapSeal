{
  "dart.enableSdkFormatter": true,
  "dart.projectSearchPaths": ["factlockcam_app"],
  "dart.analysisServerFoldingPreserved": true,
  "deno.enable": true,
  "deno.enablePaths": ["supabase/functions"],
  "deno.config": "./supabase/functions/deno.json",
  "deno.lint": true,
  "deno.unstable": [
    "bare-node-builtins",
    "byonm",
    "sloppy-imports",
    "unsafe-proto",
    "webgpu",
    "broadcast-channel",
    "worker-options",
    "cron",
    "kv",
    "ffi",
    "fs",
    "http",
    "net"
  ],
  "[typescript]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },
  "files.watcherExclude": {
    "**/factlockcam_app/build/**": true,
    "**/projects/FactLockCam_Site/dist/**": true
  }
}
